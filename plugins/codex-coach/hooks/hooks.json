{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^startup$",
        "hooks": [
          {
            "type": "command",
            "command": "codex-coach get_updates --demo --startup-json",
            "timeout": 10,
            "statusMessage": "Codex Coach checking updates"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "codex-coach record_hook_observation",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-coach record_hook_observation",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
