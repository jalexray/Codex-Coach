{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^startup$",
        "hooks": [
          {
            "type": "command",
            "command": "./plugins/codex-coach/bin/codex-coach get_updates --demo --startup-json",
            "timeout": 5,
            "statusMessage": "Codex Coach checking updates"
          }
        ]
      }
    ]
  }
}
